            <!-- Estrella 5 parcial (60%) -->
            <polygon points="107,1 109.5,8 117,8 111,12.5 113.5,20 107,15.5 100.5,20 103,12.5 97,8 104.5,8" fill="rgba(255,255,255,0.25)"/>
            <polygon points="107,1 109.5,8 117,8 111,12.5 113.5,20 107,15.5 100.5,20 103,12.5 97,8 104.5,8" fill="white" clip-path="url(#clip60)"/>
          </svg>
        </div>
        <div class="punto-txt">Profesores cercanos</div>
      </div>
    </div>

    <a class="btn-cta"
       href="https://wa.me/34666999295?text=Hola%2C+me+interesa+el+curso+intensivo+del+permiso+B+(10-20+d%C3%ADas).+%C2%BFPod%C3%A9is+darme+m%C3%A1s+informaci%C3%B3n%3F"
       target="_blank" rel="noopener">
      Quiero información
      <span>Te respondemos hoy mismo</span>
    </a>
  </div>

  <div class="divider"></div>

  <footer>
    <p class="footer-dir">
      Calle Rodrigo de Bastidas, 13<br>
      El Puerto de Santa María · Cádiz
    </p>
    <p class="footer-dir" style="margin-top: 10px;">
      Lun – Jue · 10:00 a 13:00 y 17:00 a 20:00<br>
      Viernes · 10:00 a 13:00
    </p>
    <span class="footer-num">Autoescuela familiar</span>
  </footer>

</div>

</body>
</html>
